TELEGRAM_BOT_TOKEN=
ALLOWED_LOGINS=                 # логіни-перепустки через кому: guest2026,demo-sense
REDIS_URL=                      # опційно: на сервері (Upstash/Render) для пам'яті входу; локально лишай порожнім (файл)
INDEX_URL=
DISABLE_CRON=                   # на сервері постав 1 — вимикає щоденний scrape+ingest (важкий для Render Free)
ANTHROPIC_API_KEY=              # з console.anthropic.com
VOYAGE_API_KEY=                 # з dashboard.voyageai.com — для ембедингів (RAG)
CLAUDE_MODEL=claude-haiku-4-5
SIMILARITY_THRESHOLD=0.45       # під Voyage-ембединги (нижчі скори, ніж e5)
TOP_K=14                         # скільки чанків (різних статей) подавати Claude
CHUNKS_PER_ARTICLE=2            # макс. чанків з однієї статті (2 = і покриття, і глибина деталей)
WEB_SEARCH_MAX_USES=1           # 0 = повністю вимкнути дорогий веб-пошук (RAG-порожньо → «не знаю»)
MAX_INPUT_CHARS=1000
